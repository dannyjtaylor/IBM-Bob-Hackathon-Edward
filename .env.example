# Edward Configuration

# ElevenLabs API
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# IBM Bob API
IBM_BOB_API_URL=http://localhost:8000
IBM_BOB_API_KEY=your_bob_api_key_here

# IBM Watsonx (for autonomous computer control - cloud option)
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_watsonx_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Ollama (for autonomous computer control - local option)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava:13b

# Ollama Hybrid Mode (separate vision + text models for better performance)
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_TEXT_MODEL=llama3.2:3b

# User Settings
USER_NAME=User

# Wake Word Settings
WAKE_WORD_ENABLED=true
WAKE_WORD_THRESHOLD=0.5

# Hotkey (Win+Shift+E)
HOTKEY_ENABLED=true

# Audio Settings
TTS_ENABLED=true
STT_MODEL=base

# Autonomous Control Settings
AUTONOMOUS_CONTROL_ENABLED=false
SCREENSHOT_INTERVAL=2.0
AUTO_EXECUTE_ACTIONS=false