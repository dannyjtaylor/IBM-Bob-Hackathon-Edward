# Edward Configuration

# ElevenLabs API
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# IBM Bob API
IBM_BOB_API_URL=http://localhost:8000
IBM_BOB_API_KEY=your_bob_api_key_here

# User Settings
USER_NAME=User

# Wake Word Settings
WAKE_WORD_ENABLED=true
WAKE_WORD_THRESHOLD=0.5

# Hotkey (Win+Shift+E)
HOTKEY_ENABLED=true

# Audio Settings
TTS_ENABLED=true
STT_MODEL=base